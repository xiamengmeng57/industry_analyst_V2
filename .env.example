# Anthropic API配置
ANTHROPIC_API_KEY=

# 模型配置
MODEL=claude-sonnet-4-5

# Token优化配置
MAX_TOKENS=4096
TEMPERATURE=0.5

# 性能配置
ENABLE_CHECKPOINT=true
CHECKPOINT_INTERVAL=60

# 微信公众号爬取配置
# 获取方式：登录 https://down.mptext.top 后在 API 页面查看
# 有效期：4天（与登录会话一致）
WECHAT_API_KEY=

# 网页搜索API配置（可选）
# Serper API: https://serper.dev (推荐)
SERPER_API_KEY=
# Bing Search API: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# BING_API_KEY=

# Zep Cloud 知识图谱配置
# 获取方式：访问 https://www.getzep.com/ 注册获取 API Key
# 用途：存储、更新和查询知识图谱
ZEP_API_KEY=
